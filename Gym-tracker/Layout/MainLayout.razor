@inherits LayoutComponentBase
@inject WorkoutService WorkoutService
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        @if (WorkoutService.IsInitialized && WorkoutService.NeedsPermission && !_bannerDismissed)
        {
            <div class="permission-banner">
                <span class="permission-banner__text">
                    📂 Tap to reconnect to your workout file for this session.
                </span>
                <button class="btn btn-accent permission-banner__btn" @onclick="ReconnectFile">
                    Reconnect to file
                </button>
                <button class="permission-banner__dismiss" @onclick="() => _bannerDismissed = true" title="Dismiss">✕</button>
            </div>
        }
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<PwaInstallBanner />

@code {
    private bool _bannerDismissed;

    protected override async Task OnInitializedAsync()
    {
        await WorkoutService.InitializeAsync();
    }

    private async Task ReconnectFile()
    {
        var granted = await WorkoutService.RequestPermissionAsync();
        if (!granted) _bannerDismissed = true; // hide banner even if permission was declined
    }
}
