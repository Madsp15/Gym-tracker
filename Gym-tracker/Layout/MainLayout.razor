@inherits LayoutComponentBase
@inject WorkoutService WorkoutService
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        @if (WorkoutService.IsInitialized && WorkoutService.NeedsPermission)
        {
            <div class="permission-banner">
                <span class="permission-banner__text">
                    📂 Tap to reconnect to your workout file for this session.
                </span>
                <button class="btn btn-accent permission-banner__btn" @onclick="ReconnectFile">
                    Reconnect to file
                </button>
            </div>
        }
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<PwaInstallBanner />

@code {
    protected override async Task OnInitializedAsync()
    {
        await WorkoutService.InitializeAsync();
    }

    private async Task ReconnectFile()
    {
        var granted = await WorkoutService.RequestPermissionAsync();
        if (granted)
            // Soft SPA navigation to home — re-mounts the page so data reloads with the
            // now-active permission, without a full page reload that would reset the
            // Android Chrome file-handle permission state and cause the banner to reappear.
            Nav.NavigateTo(Nav.BaseUri);
    }
}
