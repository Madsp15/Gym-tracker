<div class="mbd @(IsReadOnly ? "mbd--readonly" : "")">
    <div class="mbd__diagrams">

        <!-- ── FRONT ── -->
        <div class="mbd__view">
            <span class="mbd__view-label">Front</span>
            <svg viewBox="0 0 100 220" xmlns="http://www.w3.org/2000/svg" class="mbd__svg">
                <!-- Non-clickable structural markers -->
                <circle  cx="50" cy="12"  r="10"     fill="#283a5a"/>
                <ellipse cx="50" cy="24"  rx="6" ry="5"  fill="#283a5a"/>
                <ellipse cx="38" cy="170" rx="9" ry="6"  fill="#283a5a"/>
                <ellipse cx="62" cy="170" rx="9" ry="6"  fill="#283a5a"/>
                <ellipse cx="10" cy="129" rx="6" ry="5"  fill="#283a5a"/>
                <ellipse cx="90" cy="129" rx="6" ry="5"  fill="#283a5a"/>
                <ellipse cx="37" cy="214" rx="8" ry="5"  fill="#283a5a"/>
                <ellipse cx="63" cy="214" rx="8" ry="5"  fill="#283a5a"/>
                <!-- Quads (rendered first = lowest z-order) -->
                <g class="mbd__region" @onclick='() => Toggle("Quads")'>
                    <ellipse cx="37" cy="146" rx="13" ry="22" fill="@RegionFill("Quads")"/>
                    <ellipse cx="63" cy="146" rx="13" ry="22" fill="@RegionFill("Quads")"/>
                </g>
                <!-- Calves -->
                <g class="mbd__region" @onclick='() => Toggle("Calves")'>
                    <ellipse cx="37" cy="196" rx="9"  ry="17" fill="@RegionFill("Calves")"/>
                    <ellipse cx="63" cy="196" rx="9"  ry="17" fill="@RegionFill("Calves")"/>
                </g>
                <!-- Core / Abs -->
                <g class="mbd__region" @onclick='() => Toggle("Core")'>
                    <rect    x="29"  y="62" width="42" height="52" rx="6" fill="@RegionFill("Core")"/>
                    <ellipse cx="50" cy="113" rx="21" ry="8"              fill="@RegionFill("Core")"/>
                </g>
                <!-- Chest -->
                <g class="mbd__region" @onclick='() => Toggle("Chest")'>
                    <rect x="29" y="30" width="42" height="32" rx="7" fill="@RegionFill("Chest")"/>
                </g>
                <!-- Forearms -->
                <g class="mbd__region" @onclick='() => Toggle("Forearms")'>
                    <ellipse cx="12" cy="110" rx="7" ry="17" fill="@RegionFill("Forearms")"/>
                    <ellipse cx="88" cy="110" rx="7" ry="17" fill="@RegionFill("Forearms")"/>
                </g>
                <!-- Biceps -->
                <g class="mbd__region" @onclick='() => Toggle("Biceps")'>
                    <ellipse cx="15" cy="70" rx="9" ry="22" fill="@RegionFill("Biceps")"/>
                    <ellipse cx="85" cy="70" rx="9" ry="22" fill="@RegionFill("Biceps")"/>
                </g>
                <!-- Shoulders / Deltoids (rendered last = highest z-order on front) -->
                <g class="mbd__region" @onclick='() => Toggle("Shoulders")'>
                    <ellipse cx="21" cy="43" rx="13" ry="10" fill="@RegionFill("Shoulders")"/>
                    <ellipse cx="79" cy="43" rx="13" ry="10" fill="@RegionFill("Shoulders")"/>
                </g>
            </svg>
        </div>

        <!-- ── BACK ── -->
        <div class="mbd__view">
            <span class="mbd__view-label">Back</span>
            <svg viewBox="0 0 100 220" xmlns="http://www.w3.org/2000/svg" class="mbd__svg">
                <!-- Non-clickable structural markers -->
                <circle  cx="50" cy="12"  r="10"     fill="#283a5a"/>
                <ellipse cx="50" cy="24"  rx="6" ry="5"  fill="#283a5a"/>
                <ellipse cx="38" cy="170" rx="9" ry="6"  fill="#283a5a"/>
                <ellipse cx="62" cy="170" rx="9" ry="6"  fill="#283a5a"/>
                <ellipse cx="10" cy="129" rx="6" ry="5"  fill="#283a5a"/>
                <ellipse cx="90" cy="129" rx="6" ry="5"  fill="#283a5a"/>
                <ellipse cx="37" cy="214" rx="8" ry="5"  fill="#283a5a"/>
                <ellipse cx="63" cy="214" rx="8" ry="5"  fill="#283a5a"/>
                <!-- Hamstrings (rendered first = lowest z-order) -->
                <g class="mbd__region" @onclick='() => Toggle("Hamstrings")'>
                    <ellipse cx="37" cy="148" rx="13" ry="22" fill="@RegionFill("Hamstrings")"/>
                    <ellipse cx="63" cy="148" rx="13" ry="22" fill="@RegionFill("Hamstrings")"/>
                </g>
                <!-- Calves -->
                <g class="mbd__region" @onclick='() => Toggle("Calves")'>
                    <ellipse cx="37" cy="196" rx="9"  ry="17" fill="@RegionFill("Calves")"/>
                    <ellipse cx="63" cy="196" rx="9"  ry="17" fill="@RegionFill("Calves")"/>
                </g>
                <!-- Glutes (sits above hamstrings in z-order) -->
                <g class="mbd__region" @onclick='() => Toggle("Glutes")'>
                    <rect    x="27"  y="112" width="46" height="22" rx="5" fill="@RegionFill("Glutes")"/>
                    <ellipse cx="50" cy="134" rx="23"  ry="9"               fill="@RegionFill("Glutes")"/>
                </g>
                <!-- Lower Back / Lumbar -->
                <g class="mbd__region" @onclick='() => Toggle("Lower Back")'>
                    <rect x="30" y="90" width="40" height="22" rx="5" fill="@RegionFill("Lower Back")"/>
                </g>
                <!-- Back / Lats & Mid-back -->
                <g class="mbd__region" @onclick='() => Toggle("Back")'>
                    <rect x="25" y="60" width="50" height="30" rx="8" fill="@RegionFill("Back")"/>
                </g>
                <!-- Forearms -->
                <g class="mbd__region" @onclick='() => Toggle("Forearms")'>
                    <ellipse cx="12" cy="110" rx="7" ry="17" fill="@RegionFill("Forearms")"/>
                    <ellipse cx="88" cy="110" rx="7" ry="17" fill="@RegionFill("Forearms")"/>
                </g>
                <!-- Triceps -->
                <g class="mbd__region" @onclick='() => Toggle("Triceps")'>
                    <ellipse cx="15" cy="70" rx="9" ry="22" fill="@RegionFill("Triceps")"/>
                    <ellipse cx="85" cy="70" rx="9" ry="22" fill="@RegionFill("Triceps")"/>
                </g>
                <!-- Traps / Trapezius – pentagon centred on upper spine -->
                <g class="mbd__region" @onclick='() => Toggle("Traps")'>
                    <polygon points="50,28 68,44 60,60 40,60 32,44" fill="@RegionFill("Traps")"/>
                </g>
                <!-- Shoulders / Rear Deltoids (rendered last = highest z-order on back) -->
                <g class="mbd__region" @onclick='() => Toggle("Shoulders")'>
                    <ellipse cx="21" cy="43" rx="13" ry="10" fill="@RegionFill("Shoulders")"/>
                    <ellipse cx="79" cy="43" rx="13" ry="10" fill="@RegionFill("Shoulders")"/>
                </g>
            </svg>
        </div>

    </div>

    <!-- Active muscle label -->
    @if (ShowLabel)
    {
        <div class="mbd__label">
            @if (IsReadOnly)
            {
                @if (ReadOnlyMuscleGroups!.Any())
                {
                    <span class="mbd__label--active">@string.Join(" · ", ReadOnlyMuscleGroups!.OrderBy(m => m))</span>
                }
                else
                {
                    <span class="mbd__label--hint">No muscles tagged</span>
                }
            }
            else
            {
                @if (string.IsNullOrEmpty(MuscleGroup))
                {
                    <span class="mbd__label--hint">Tap a region to tag</span>
                }
                else
                {
                    <span class="mbd__label--active">@MuscleGroup</span>
                    <button type="button" class="mbd__clear" @onclick="Clear">✕</button>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public string?               MuscleGroup          { get; set; }
    [Parameter] public EventCallback<string> MuscleGroupChanged   { get; set; }
    [Parameter] public IEnumerable<string>?  ReadOnlyMuscleGroups { get; set; }
    [Parameter] public bool                  ShowLabel            { get; set; } = true;

    private bool IsReadOnly => ReadOnlyMuscleGroups is not null;

    private string RegionFill(string group) =>
        IsActive(group) ? "#6A5BC2" : "#1e2a40";

    private bool IsActive(string group) =>
        IsReadOnly
            ? ReadOnlyMuscleGroups!.Any(m => string.Equals(m, group, StringComparison.OrdinalIgnoreCase))
            : string.Equals(MuscleGroup, group, StringComparison.OrdinalIgnoreCase);

    private async Task Toggle(string group)
    {
        if (IsReadOnly) return;
        var next = string.Equals(MuscleGroup, group, StringComparison.OrdinalIgnoreCase)
            ? string.Empty : group;
        await MuscleGroupChanged.InvokeAsync(next);
    }

    private async Task Clear() => await MuscleGroupChanged.InvokeAsync(string.Empty);
}
