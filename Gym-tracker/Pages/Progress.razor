    private int TotalDaysActive
    {
        get
        {
            if (_workouts is null || _workouts.Count == 0) return 0;
            var earliest = _workouts.Min(w => w.Date).Date;
            return (int)(DateTime.Today - earliest).TotalDays + 1;
        }
    }

    private int WorkoutsThisWeek
    {
        get
        {
            if (_workouts is null) return 0;
            var today          = DateTime.Today;
            var daysFromMonday = ((int)today.DayOfWeek + 6) % 7;
            var monday         = today.AddDays(-daysFromMonday);
            return _workouts.Count(w => w.Date.Date >= monday);
        }
    }

    private int TotalSetsLogged =>
        _workouts?.Sum(w => w.Exercises.Sum(e => e.Sets.Count)) ?? 0;

    private string TotalVolumeStr
    {
        get
        {
            if (_workouts is null) return "0";
            var kg = _workouts
                .SelectMany(w => w.Exercises)
                .Where(e => e.Type == ExerciseType.RepsWeight)
                .SelectMany(e => e.Sets)
                .Where(s => s.WeightKg > 0 && s.Reps > 0)
                .Sum(s => s.WeightKg!.Value * s.Reps!.Value);
            var v = _isMetric ? kg : kg * 2.20462;
            if (v >= 1_000_000) return $"{v / 1_000_000:0.#}M";
            if (v >= 1_000)     return $"{v / 1_000:0.#}k";
            return ((int)v).ToString();
        }
    }

    private string FavouriteDay
    {
        get
        {
            if (_workouts is null || _workouts.Count < 3) return "–";
            return _workouts
                .GroupBy(w => w.Date.DayOfWeek)
                .OrderByDescending(g => g.Count())
                .First().Key switch
            {
                DayOfWeek.Monday    => "Monday",
                DayOfWeek.Tuesday   => "Tuesday",
                DayOfWeek.Wednesday => "Wednesday",
                DayOfWeek.Thursday  => "Thursday",
                DayOfWeek.Friday    => "Friday",
                DayOfWeek.Saturday  => "Saturday",
                DayOfWeek.Sunday    => "Sunday",
                _                   => "–"
            };
        }
    }

