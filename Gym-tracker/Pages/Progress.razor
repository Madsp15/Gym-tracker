@page "/progress"
@using System.Globalization
@inject WorkoutService WorkoutService
@inject IJSRuntime JS

<PageTitle>Progress – Gym Tracker</PageTitle>

<div class="page-header">
    <h2 class="page-header__title">Progress</h2>
</div>

@if (!WorkoutService.IsInitialized)
{
    <p class="text-muted ps-3">Loading…</p>
}
else if (_workouts is null)
{
    <p class="text-muted ps-3">Loading…</p>
}
else if (_workouts.Count == 0)
{
    <div class="empty-state">
        <p class="empty-state__icon">📈</p>
        <p class="empty-state__text">No workouts logged yet. Log your first workout to start tracking progress!</p>
        <a class="btn btn-accent" href="workouts/log">+ Log Workout</a>
    </div>
}
else
{
    <div class="progress-summary">
        <div class="progress-summary__tile">
            <div class="progress-summary__value">@_workouts.Count</div>
            <div class="progress-summary__label">Workouts</div>
        </div>
        <div class="progress-summary__tile">
            <div class="progress-summary__value">@_stats.Count</div>
            <div class="progress-summary__label">Exercises</div>
        </div>
        <div class="progress-summary__tile">
            <div class="progress-summary__value">@TotalDaysActive</div>
            <div class="progress-summary__label">Days tracked</div>
        </div>
        <div class="progress-summary__tile">
            <div class="progress-summary__value">@WorkoutsThisWeek</div>
            <div class="progress-summary__label">This week</div>
        </div>
    </div>

    <div class="progress-highlights">
        <div class="progress-highlights__chip">
            <div class="progress-highlights__value">@TotalDaysActive</div>
            <div class="progress-highlights__label">Days since start</div>
        </div>
        <div class="progress-highlights__chip">
            <div class="progress-highlights__value">@TotalSetsLogged</div>
            <div class="progress-highlights__label">Total sets</div>
        </div>
        <div class="progress-highlights__chip">
            <div class="progress-highlights__value">@TotalVolumeStr<span class="progress-highlights__unit"> @WeightUnit</span></div>
            <div class="progress-highlights__label">Volume lifted</div>
        </div>
        <div class="progress-highlights__chip">
            <div class="progress-highlights__value">@FavouriteDay</div>
            <div class="progress-highlights__label">Favourite day</div>
        </div>
        <div class="progress-highlights__chip" title="Consecutive weeks containing at least one workout (counted up to this week or last week)">
            <div class="progress-highlights__value">@CurrentStreakWeeks<span class="progress-highlights__unit"> wk</span></div>
            <div class="progress-highlights__label">Current streak</div>
        </div>
        <div class="progress-highlights__chip" title="Longest run of consecutive weeks with a workout">
            <div class="progress-highlights__value">@LongestStreakWeeks<span class="progress-highlights__unit"> wk</span></div>
            <div class="progress-highlights__label">Best streak</div>
        </div>
    </div>

    <div class="progress-range">
        <span class="progress-range__label">Range:</span>
        @foreach (var r in RangePresets)
        {
            var days = r.Days;
            <button class="progress-range__btn @(_rangeDays == days ? "progress-range__btn--active" : "")"
                    @onclick="() => SetRange(days)">@r.Label</button>
        }
    </div>

    <details class="progress-heatmap">
        <summary class="progress-heatmap__summary">Activity heatmap (last 53 weeks)</summary>
        <div class="progress-heatmap__wrap">
            <svg viewBox="0 0 750 105" xmlns="http://www.w3.org/2000/svg" class="progress-heatmap__svg"
                 role="img" aria-label="Workout activity heatmap, one cell per day for the last 53 weeks">
                <title>Workout activity heatmap</title>
                @{
                    var cells = HeatCells;
                    const int cell = 12, gap = 2;
                    int col = 0;
                }
                @for (int i = 0; i < cells.Count; i++)
                {
                    var c   = cells[i];
                    var row = ((int)c.Date.DayOfWeek + 6) % 7; // Monday-first
                    var x   = col * (cell + gap);
                    var y   = row * (cell + gap);
                    <rect x="@x" y="@y" width="@cell" height="@cell" rx="2"
                          class="heatmap-cell heatmap-cell--lvl@(HeatLevel(c.Count))">
                        <title>@c.Date.ToString("ddd d MMM yyyy"): @c.Count workout@(c.Count == 1 ? "" : "s")</title>
                    </rect>
                    if (row == 6) { col++; }
                }
            </svg>
            <div class="progress-heatmap__legend">
                <span>Less</span>
                <span class="heatmap-legend heatmap-cell--lvl0"></span>
                <span class="heatmap-legend heatmap-cell--lvl1"></span>
                <span class="heatmap-legend heatmap-cell--lvl2"></span>
                <span class="heatmap-legend heatmap-cell--lvl3"></span>
                <span class="heatmap-legend heatmap-cell--lvl4"></span>
                <span>More</span>
            </div>
        </div>
    </details>

    @if (AvailableMuscleGroups.Count > 0)
    {
        <div class="progress-filter">
            <span class="progress-filter__label">Muscle:</span>
            <button class="progress-filter__btn @(_muscleFilter is null ? "progress-filter__btn--active" : "")"
                    @onclick="() => _muscleFilter = null">All</button>
            @foreach (var grp in AvailableMuscleGroups)
            {
                var mg = grp;
                <button class="progress-filter__btn @(_muscleFilter == mg ? "progress-filter__btn--active" : "")"
                        @onclick="() => _muscleFilter = mg">@mg</button>
            }
        </div>
    }

    <div class="progress-sort">
        <span class="progress-sort__label">Sort by:</span>
        <button class="progress-sort__btn @(_sort == "recent" ? "progress-sort__btn--active" : "")" @onclick="SortByRecent">Recent</button>
        <button class="progress-sort__btn @(_sort == "improved" ? "progress-sort__btn--active" : "")" @onclick="SortByImproved">Most improved</button>
        <button class="progress-sort__btn @(_sort == "alpha" ? "progress-sort__btn--active" : "")" @onclick="SortByAlpha">A–Z</button>
        <button class="progress-sort__btn @(_sort == "template" ? "progress-sort__btn--active" : "")" @onclick="SortByTemplate">Workouts</button>
    </div>

    <div class="progress-cards">
        @if (!AllGroups.Any(g => g.Stats.Count > 0))
        {
            <div class="progress-empty">
                <span class="progress-empty__icon">🔍</span>
                <span class="progress-empty__text">No exercises match the current filters.</span>
            </div>
        }
        @foreach (var group in AllGroups)
        {
            @if (!string.IsNullOrEmpty(group.Name))
            {
                <div class="progress-group-header">
                    <span class="progress-group-header__name">@group.Name</span>
                    <span class="progress-group-header__count">@group.Stats.Count exercise@(group.Stats.Count == 1 ? "" : "s")</span>
                </div>
            }
            @foreach (var s in group.Stats)
            {
            <div class="progress-card">
                <div class="progress-card__header">
                    <span class="progress-card__name">@s.Name</span>
                    <span class="progress-card__type-badge @(s.Type == ExerciseType.Timed ? "progress-card__type-badge--timed" : s.Type == ExerciseType.Cardio ? "progress-card__type-badge--cardio" : "")">
                        @(s.Type == ExerciseType.Timed ? "Timed" : s.Type == ExerciseType.Cardio ? "Cardio" : "Reps")
                    </span>
                </div>

                <div class="progress-card__meta-row">
                    <span class="progress-card__meta">@DaysSinceText(s.LastDate)</span>
                    <span class="progress-card__meta">
                        @s.SessionCount session@(s.SessionCount == 1 ? "" : "s")
                        @if (s.PrCount > 0)
                        {
                            <span class="progress-card__pr-badge" title="Sessions that beat all previous bests">🏆 ×@s.PrCount</span>
                        }
                        @if (s.PoCount > 0)
                        {
                            <span class="progress-card__po-badge" title="Sessions you flagged as progressive overload">PO ×@s.PoCount</span>
                        }
                    </span>
                </div>

                <div class="progress-card__date-range">
                    First:&nbsp;@s.FirstDate.ToString("d MMM yyyy")&nbsp;&nbsp;·&nbsp;&nbsp;Latest:&nbsp;@s.LastDate.ToString("d MMM yyyy")
                </div>

                @if (s.Type == ExerciseType.RepsWeight && s.FirstBestWeight.HasValue)
                {
                    <div class="progress-card__metric">
                        <div class="progress-card__metric-header">
                            <span class="progress-card__metric-label">Best weight per session</span>
                            <span class="progress-card__metric-delta @DeltaCssClass(s.WeightDelta)">
                                @WeightDeltaText(s)
                            </span>
                        </div>
                        <div class="progress-card__weight-values">
                            <span>@FormatWeight(s.FirstBestWeight.Value)</span>
                            <span class="progress-card__arrow">→</span>
                            <span class="progress-card__weight-latest">@(s.LatestBestWeight.HasValue ? FormatWeight(s.LatestBestWeight.Value) : "–")</span>
                        </div>
                        <div class="progress-bar-track">
                            <div class="progress-bar-fill" style="@BarStyle(s.BarWidthPct)"></div>
                        </div>
                        <div class="progress-card__bar-label">All-time best: @(s.AllTimeBestWeight.HasValue ? FormatWeight(s.AllTimeBestWeight.Value) : "–")</div>
                        @if (s.BestEstimated1RM.HasValue)
                        {
                            <div class="progress-card__1rm">Est. 1RM: <strong>@FormatWeight(s.BestEstimated1RM.Value)</strong></div>
                        }
                    </div>
                }
                else if (s.Type == ExerciseType.Timed && s.FirstBestDuration.HasValue)
                {
                    <div class="progress-card__metric">
                        <div class="progress-card__metric-header">
                            <span class="progress-card__metric-label">Best duration per session</span>
                            <span class="progress-card__metric-delta @DeltaCssClass(s.DurationDelta)">
                                @DurationDeltaText(s)
                            </span>
                        </div>
                        <div class="progress-card__weight-values">
                            <span>@FormatDuration(s.FirstBestDuration.Value)</span>
                            <span class="progress-card__arrow">→</span>
                            <span class="progress-card__weight-latest">@(s.LatestBestDuration.HasValue ? FormatDuration(s.LatestBestDuration.Value) : "–")</span>
                        </div>
                        <div class="progress-bar-track">
                            <div class="progress-bar-fill" style="@BarStyle(s.DurationBarWidthPct)"></div>
                        </div>
                        <div class="progress-card__bar-label">All-time best: @(s.AllTimeBestDuration.HasValue ? FormatDuration(s.AllTimeBestDuration.Value) : "–")</div>
                    </div>
                }
                else if (s.Type == ExerciseType.Cardio && s.FirstBestDistance.HasValue)
                {
                    <div class="progress-card__metric">
                        <div class="progress-card__metric-header">
                            <span class="progress-card__metric-label">Best distance per session</span>
                            <span class="progress-card__metric-delta @DeltaCssClass(s.DistanceDelta)">
                                @DistanceDeltaText(s)
                            </span>
                        </div>
                        <div class="progress-card__weight-values">
                            <span>@FormatDistance(s.FirstBestDistance.Value)</span>
                            <span class="progress-card__arrow">→</span>
                            <span class="progress-card__weight-latest">@(s.LatestBestDistance.HasValue ? FormatDistance(s.LatestBestDistance.Value) : "–")</span>
                        </div>
                        <div class="progress-bar-track">
                            <div class="progress-bar-fill" style="@BarStyle(s.DistanceBarWidthPct)"></div>
                        </div>
                        <div class="progress-card__bar-label">All-time best: @(s.AllTimeBestDistance.HasValue ? FormatDistance(s.AllTimeBestDistance.Value) : "–")</div>
                    </div>
                    @if (s.FirstBestPace.HasValue)
                    {
                        <div class="progress-card__metric">
                            <div class="progress-card__metric-header">
                                <span class="progress-card__metric-label">Best pace per session</span>
                                <span class="progress-card__metric-delta @PaceDeltaCssClass(s.PaceDelta)">
                                    @PaceDeltaText(s)
                                </span>
                            </div>
                            <div class="progress-card__weight-values">
                                <span>@FormatPace(s.FirstBestPace.Value)</span>
                                <span class="progress-card__arrow">→</span>
                                <span class="progress-card__weight-latest">@(s.LatestBestPace.HasValue ? FormatPace(s.LatestBestPace.Value) : "–")</span>
                            </div>
                            <div class="progress-bar-track">
                                <div class="progress-bar-fill progress-bar-fill--pace" style="@BarStyle(s.PaceBarWidthPct)"></div>
                            </div>
                            <div class="progress-card__bar-label">All-time best: @(s.AllTimeBestPace.HasValue ? FormatPace(s.AllTimeBestPace.Value) : "–")</div>
                        </div>
                    }
                    @if (s.TotalDistanceKm > 0)
                    {
                        <div class="progress-card__total-distance">Total: @FormatDistance(s.TotalDistanceKm)</div>
                    }
                }
                else
                {
                    <div class="progress-card__no-data">No data recorded yet.</div>
                }

                <div class="progress-card__extra-stats">
                    @if (s.SessionCount > 1)
                    {
                        <span class="progress-card__stat-chip">@s.AvgGapText</span>
                    }
                    @if (!string.IsNullOrEmpty(s.FrequencyText))
                    {
                        <span class="progress-card__stat-chip">@s.FrequencyText</span>
                    }
                    @if (s.Type == ExerciseType.RepsWeight && s.TotalVolumeKg > 0)
                    {
                        <span class="progress-card__stat-chip">@FormatVolume(s.TotalVolumeKg) total vol.</span>
                    }
                </div>

                <div class="progress-card__footer">
                    @if (s.Type == ExerciseType.Cardio)
                    {
                        <span class="progress-card__volume">
                            @s.TotalSets set@(s.TotalSets == 1 ? "" : "s") logged
                            @if (s.TotalDistanceKm > 0)
                            {
                                <span> · @FormatDistance(s.TotalDistanceKm) total</span>
                            }
                        </span>
                    }
                    else if (s.TotalSets > 0)
                    {
                        <span class="progress-card__volume">
                            @s.TotalSets set@(s.TotalSets == 1 ? "" : "s") logged
                            @if (s.TotalReps > 0)
                            {
                                <span> · @s.TotalReps rep@(s.TotalReps == 1 ? "" : "s") total</span>
                            }
                        </span>
                    }
                    @if (s.Type == ExerciseType.Cardio && s.FirstBestPace.HasValue)
                    {
                        <button class="progress-chart__toggle" @onclick="() => TogglePaceChart(s)">
                            @(_expandedPaceCharts.Contains(s.Name) ? "▲ Hide pace" : "▾ Pace")
                        </button>
                    }
                    @if (s.Type == ExerciseType.RepsWeight && s.TotalVolumeKg > 0)
                    {
                        <button class="progress-chart__toggle" @onclick="() => ToggleVolumeChart(s)">
                            @(_expandedVolumeCharts.Contains(s.Name) ? "▲ Hide volume" : "▾ Volume")
                        </button>
                    }
                    <button class="progress-chart__toggle" @onclick="() => ToggleChart(s)">
                        @(_expandedCharts.Contains(s.Name) ? "▲ Hide chart" : "▾ Chart")
                    </button>
                </div>

                @if (s.Type == ExerciseType.Cardio && _expandedPaceCharts.Contains(s.Name))
                {
                    @if (PaceChartOf(s.Name).Points.Count >= 1)
                    {
                        <div class="progress-chart">
                            <div class="progress-chart__subtitle">Pace over time · lower = faster</div>
                            <svg viewBox="0 0 560 165" xmlns="http://www.w3.org/2000/svg" class="progress-chart__svg"
                                 role="img" aria-label="Pace over time for @s.Name">
                                <title>@s.Name – pace over time</title>
                                <line x1="50" y1="10"  x2="550" y2="10"  class="chart-grid" />
                                <line x1="50" y1="49"  x2="550" y2="49"  class="chart-grid" />
                                <line x1="50" y1="87"  x2="550" y2="87"  class="chart-grid" />
                                <line x1="50" y1="125" x2="550" y2="125" class="chart-grid chart-grid--axis" />
                                <line x1="50" y1="10"  x2="50"  y2="125" class="chart-grid chart-grid--axis" />
                                <text x="45" y="14"  class="chart-label" text-anchor="end">@PaceChartOf(s.Name).YMaxLabel</text>
                                <text x="45" y="128" class="chart-label" text-anchor="end">@PaceChartOf(s.Name).YMinLabel</text>
                                <path d="@PaceChartOf(s.Name).AreaPath" class="chart-area chart-area--pace" />
                                <path d="@PaceChartOf(s.Name).LinePath" class="chart-line chart-line--pace" />
                                @foreach (var pt in PaceChartOf(s.Name).Points)
                                {
                                    <circle cx="@Fmt(pt.X)" cy="@Fmt(pt.Y)" r="3.5" class="chart-dot chart-dot--pace">
                                        <title>@pt.DateLabel: @pt.ValueLabel</title>
                                    </circle>
                                }
                                <text x="50"  y="150" class="chart-label" text-anchor="start">@PaceChartOf(s.Name).FirstDateLabel</text>
                                <text x="550" y="150" class="chart-label" text-anchor="end">@PaceChartOf(s.Name).LastDateLabel</text>
                            </svg>
                        </div>
                    }
                    else
                    {
                        <p class="progress-chart__empty">Not enough data for a pace chart yet.</p>
                    }
                }

                @if (_expandedCharts.Contains(s.Name))
                {
                    @if (ChartOf(s.Name).Points.Count >= 1)
                    {
                        <div class="progress-chart">
                            <svg viewBox="0 0 560 165" xmlns="http://www.w3.org/2000/svg" class="progress-chart__svg"
                                 role="img" aria-label="Best metric per session for @s.Name">
                                <title>@s.Name – best metric per session</title>
                                <line x1="50" y1="10"  x2="550" y2="10"  class="chart-grid" />
                                <line x1="50" y1="49"  x2="550" y2="49"  class="chart-grid" />
                                <line x1="50" y1="87"  x2="550" y2="87"  class="chart-grid" />
                                <line x1="50" y1="125" x2="550" y2="125" class="chart-grid chart-grid--axis" />
                                <line x1="50" y1="10"  x2="50"  y2="125" class="chart-grid chart-grid--axis" />
                                <text x="45" y="14"  class="chart-label" text-anchor="end">@ChartOf(s.Name).YMaxLabel</text>
                                <text x="45" y="128" class="chart-label" text-anchor="end">@ChartOf(s.Name).YMinLabel</text>
                                <path d="@ChartOf(s.Name).AreaPath" class="chart-area" />
                                <path d="@ChartOf(s.Name).LinePath" class="chart-line" />
                                @foreach (var pt in ChartOf(s.Name).Points)
                                {
                                    <circle cx="@Fmt(pt.X)" cy="@Fmt(pt.Y)" r="3.5" class="chart-dot">
                                        <title>@pt.DateLabel: @pt.ValueLabel</title>
                                    </circle>
                                }
                                <text x="50"  y="150" class="chart-label" text-anchor="start">@ChartOf(s.Name).FirstDateLabel</text>
                                <text x="550" y="150" class="chart-label" text-anchor="end">@ChartOf(s.Name).LastDateLabel</text>
                            </svg>
                        </div>
                    }
                    else
                    {
                        <p class="progress-chart__empty">Not enough data for a chart yet.</p>
                    }
                }

                @if (s.Type == ExerciseType.RepsWeight && _expandedVolumeCharts.Contains(s.Name))
                {
                    @if (VolumeChartOf(s.Name).Points.Count >= 1)
                    {
                        <div class="progress-chart">
                            <div class="progress-chart__subtitle">Total volume per session (sets × reps × weight)</div>
                            <svg viewBox="0 0 560 165" xmlns="http://www.w3.org/2000/svg" class="progress-chart__svg"
                                 role="img" aria-label="Total volume per session for @s.Name">
                                <title>@s.Name – volume per session</title>
                                <line x1="50" y1="10"  x2="550" y2="10"  class="chart-grid" />
                                <line x1="50" y1="49"  x2="550" y2="49"  class="chart-grid" />
                                <line x1="50" y1="87"  x2="550" y2="87"  class="chart-grid" />
                                <line x1="50" y1="125" x2="550" y2="125" class="chart-grid chart-grid--axis" />
                                <line x1="50" y1="10"  x2="50"  y2="125" class="chart-grid chart-grid--axis" />
                                <text x="45" y="14"  class="chart-label" text-anchor="end">@VolumeChartOf(s.Name).YMaxLabel</text>
                                <text x="45" y="128" class="chart-label" text-anchor="end">@VolumeChartOf(s.Name).YMinLabel</text>
                                <path d="@VolumeChartOf(s.Name).AreaPath" class="chart-area chart-area--volume" />
                                <path d="@VolumeChartOf(s.Name).LinePath" class="chart-line chart-line--volume" />
                                @foreach (var pt in VolumeChartOf(s.Name).Points)
                                {
                                    <circle cx="@Fmt(pt.X)" cy="@Fmt(pt.Y)" r="3.5" class="chart-dot chart-dot--volume">
                                        <title>@pt.DateLabel: @pt.ValueLabel</title>
                                    </circle>
                                }
                                <text x="50"  y="150" class="chart-label" text-anchor="start">@VolumeChartOf(s.Name).FirstDateLabel</text>
                                <text x="550" y="150" class="chart-label" text-anchor="end">@VolumeChartOf(s.Name).LastDateLabel</text>
                            </svg>
                        </div>
                    }
                    else
                    {
                        <p class="progress-chart__empty">Not enough data for a volume chart yet.</p>
                    }
                }
            </div>
            }
        }
    </div>
}

@code {
    private List<LoggedWorkout>?          _workouts;
    private List<WorkoutTemplate>?        _templates;
    private List<ExerciseStat>            _stats             = new();
    private string                        _sort              = "recent";
    private HashSet<string>               _expandedCharts       = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string>               _expandedPaceCharts   = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string>               _expandedVolumeCharts = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, ChartData> _chartDataCache       = new(StringComparer.OrdinalIgnoreCase);
    private string?                       _muscleFilter;

    // ── Weight unit ───────────────────────────────────────────────────
    private bool   _isMetric  = true;
    private string WeightUnit => _isMetric ? "kg" : "lbs";

    // ── Distance unit ─────────────────────────────────────────────────
    private bool   _isKm        = true;
    private string DistanceUnit => _isKm ? "km" : "mi";

    // ── Date range filter ─────────────────────────────────────────────
    // 0 = all time. Persisted in localStorage under gym_tracker_progress_range.
    private int _rangeDays = 0;

    private static readonly (int Days, string Label)[] RangePresets =
    {
        (30,  "30d"),
        (90,  "90d"),
        (365, "1y"),
        (0,   "All"),
    };

    private List<LoggedWorkout> WorkoutsInRange
    {
        get
        {
            if (_workouts is null) return new();
            if (_rangeDays <= 0) return _workouts;
            var cutoff = DateTime.Today.AddDays(-_rangeDays);
            return _workouts.Where(w => w.Date.Date >= cutoff).ToList();
        }
    }

    private async Task SetRange(int days)
    {
        if (_rangeDays == days) return;
        _rangeDays = days;
        await JS.InvokeVoidAsync("localStorage.setItem", "gym_tracker_progress_range", days.ToString());
        // Stats are derived from the current range, so rebuild and drop cached charts.
        _chartDataCache.Clear();
        _expandedCharts.Clear();
        _expandedPaceCharts.Clear();
        _expandedVolumeCharts.Clear();
        BuildStats();
    }

    // ── Streaks (consecutive ISO weeks containing ≥1 workout) ────────

    private int CurrentStreakWeeks => ComputeStreaks().Current;
    private int LongestStreakWeeks => ComputeStreaks().Longest;

    private (int Current, int Longest) ComputeStreaks()
    {
        if (_workouts is null || _workouts.Count == 0) return (0, 0);

        // Set of (Year, ISO week) buckets that contain at least one workout.
        var weeks = _workouts
            .Select(w => MondayOf(w.Date))
            .Distinct()
            .OrderBy(d => d)
            .ToList();
        if (weeks.Count == 0) return (0, 0);

        int longest = 1, run = 1;
        for (int i = 1; i < weeks.Count; i++)
        {
            if ((weeks[i] - weeks[i - 1]).TotalDays == 7) run++;
            else run = 1;
            if (run > longest) longest = run;
        }

        // Current = run anchored to the week of today (or last week, to avoid breaking on Monday).
        var currentWeek  = MondayOf(DateTime.Today);
        var previousWeek = currentWeek.AddDays(-7);
        var anchor       = weeks.Last();
        int current = 0;
        if (anchor == currentWeek || anchor == previousWeek)
        {
            current = 1;
            for (int i = weeks.Count - 1; i > 0; i--)
            {
                if ((weeks[i] - weeks[i - 1]).TotalDays == 7) current++;
                else break;
            }
        }
        return (current, longest);
    }

    private static DateTime MondayOf(DateTime d)
    {
        var date           = d.Date;
        var daysFromMonday = ((int)date.DayOfWeek + 6) % 7;
        return date.AddDays(-daysFromMonday);
    }

    // ── Activity heatmap (last 53 weeks, GitHub-style) ────────────────

    private sealed record HeatCell(DateTime Date, int Count);

    private IReadOnlyList<HeatCell> HeatCells
    {
        get
        {
            if (_workouts is null) return Array.Empty<HeatCell>();
            var counts = _workouts
                .GroupBy(w => w.Date.Date)
                .ToDictionary(g => g.Key, g => g.Count());

            // 53 columns × 7 rows ending on Sunday of the current week.
            var endSunday = MondayOf(DateTime.Today).AddDays(6);
            var start     = endSunday.AddDays(-(53 * 7) + 1);
            var cells     = new List<HeatCell>(53 * 7);
            for (var d = start; d <= endSunday; d = d.AddDays(1))
                cells.Add(new HeatCell(d, counts.TryGetValue(d, out var c) ? c : 0));
            return cells;
        }
    }

    private static int HeatLevel(int count) => count switch
    {
        0   => 0,
        1   => 1,
        2   => 2,
        3   => 3,
        _   => 4
    };

