    private string WeightDeltaText(ExerciseStat s)
    {
        if (s.WeightDelta is null) return "–";
        var d    = s.WeightDelta.Value;
        var dv   = _isMetric ? d : Math.Round(d * 2.20462, 1);
        var sign = dv > 0 ? "+" : "";
        var text = $"{sign}{dv.ToString("0.##", CultureInfo.InvariantCulture)} {WeightUnit}";
        if (s.WeightDeltaPct is not null)
            text += $" ({(d > 0 ? "+" : "")}{s.WeightDeltaPct.Value.ToString("0.#", CultureInfo.InvariantCulture)}%)";
        return text;
    }

    private static string DurationDeltaText(ExerciseStat s)
    {
        if (s.DurationDelta is null) return "–";
        var d    = s.DurationDelta.Value;
        var sign = d > 0 ? "+" : (d < 0 ? "-" : "");
        var text = $"{sign}{FormatDuration(Math.Abs(d))}";
        if (s.DurationDeltaPct is not null)
            text += $" ({(d > 0 ? "+" : "")}{s.DurationDeltaPct.Value.ToString("0.#", CultureInfo.InvariantCulture)}%)";
        return text;
    }

    private string DistanceDeltaText(ExerciseStat s)
    {
        if (s.DistanceDelta is null) return "–";
        var d    = s.DistanceDelta.Value;
        var sign = d > 0 ? "+" : "";
        var text = $"{sign}{FormatDistance(Math.Abs(d))}";
        if (s.DistanceDeltaPct is not null)
            text += $" ({(d > 0 ? "+" : "")}{s.DistanceDeltaPct.Value.ToString("0.#", CultureInfo.InvariantCulture)}%)";
        return text;
    }

    private string FormatPace(double minPerKm)
    {
        if (minPerKm <= 0) return "–";
        // convert to min/mi if needed (1 mi = 1.60934 km)
        var paceDisplay = _isKm ? minPerKm : minPerKm * 1.60934;
        var mins = (int)paceDisplay;
        var secs = (int)Math.Round((paceDisplay - mins) * 60);
        if (secs == 60) { mins++; secs = 0; }
        return $"{mins}:{secs:D2} /{DistanceUnit}";
    }

    private string PaceDeltaText(ExerciseStat s)
    {
        if (s.PaceDelta is null) return "–";
        var d    = _isKm ? s.PaceDelta.Value : s.PaceDelta.Value * 1.60934;
        var abs  = Math.Abs(d);
        var mins = (int)abs;
        var secs = (int)Math.Round((abs - mins) * 60);
        if (secs == 60) { mins++; secs = 0; }
        return $"{(d < 0 ? "−" : "+")}{mins}:{secs:D2} /{DistanceUnit}";
    }

