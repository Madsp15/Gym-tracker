    private static string PaceDeltaCssClass(double? delta) => delta switch
    {
        < 0 => "progress-card__metric-delta--up",
        > 0 => "progress-card__metric-delta--down",
        _   => "progress-card__metric-delta--same"
    };

    private ChartData BuildPaceChartData(ExerciseStat s)
    {
        var pts = BuildPaceChartPoints(s);
        if (pts.Count == 0) return ChartData.Empty;

        var fastest   = s.AllTimeBestPace  ?? 0;
        var slowest   = s.SessionHistory.Where(h => h.Pace > 0).Select(h => h.Pace!.Value).DefaultIfEmpty(0).Max();
        var firstDate = s.SessionHistory.First().Date.ToString("d MMM");
        var lastDate  = s.SessionHistory.Last().Date.ToString("d MMM yyyy");

        return new ChartData(pts, BuildLinePath(pts), BuildAreaPath(pts),
            FormatPace(fastest), FormatPace(slowest), firstDate, lastDate);
    }

    private List<ChartPoint> BuildPaceChartPoints(ExerciseStat s)
    {
        var history = s.SessionHistory;
        if (history.Count == 0) return new();

        var dataPoints = history
            .Where(h => h.Pace.HasValue && h.Pace.Value > 0)
            .Select(h => (h.Date, Pace: h.Pace!.Value))
            .ToList();
        if (dataPoints.Count == 0) return new();

        var fastest   = dataPoints.Min(p => p.Pace);
        var slowest   = dataPoints.Max(p => p.Pace);
        var yFast     = fastest * 0.97;
        var ySlow     = slowest * 1.03;
        var yRange    = ySlow - yFast;
        var minTicks  = dataPoints.Min(p => p.Date.Ticks);
        var maxTicks  = dataPoints.Max(p => p.Date.Ticks);
        var tickRange = maxTicks - minTicks;

        return dataPoints.Select((p, i) =>
        {
            var x = tickRange > 0
                ? CL + (double)(p.Date.Ticks - minTicks) / tickRange * CW
                : (dataPoints.Count > 1 ? CL + (double)i / (dataPoints.Count - 1) * CW : CL + CW / 2);
            // Inverted: faster (lower pace) → top (CT), slower → bottom (CB)
            var y = yRange > 0 ? CT + (p.Pace - yFast) / yRange * CH : CT + CH / 2d;
            return new ChartPoint(x, y, p.Date.ToString("d MMM yyyy"), FormatPace(p.Pace));
        }).ToList();
    }

    private ChartData BuildVolumeChartData(ExerciseStat s)
    {
        var pts = BuildVolumeChartPoints(s);
        if (pts.Count == 0) return ChartData.Empty;

        var rawMax    = s.SessionHistory.Where(h => h.Volume.HasValue).Select(h => h.Volume!.Value).DefaultIfEmpty(0d).Max();
        var firstDate = s.SessionHistory.First().Date.ToString("d MMM");
        var lastDate  = s.SessionHistory.Last().Date.ToString("d MMM yyyy");

        return new ChartData(pts, BuildLinePath(pts), BuildAreaPath(pts),
            FormatVolume(rawMax), "0", firstDate, lastDate);
    }

    private List<ChartPoint> BuildVolumeChartPoints(ExerciseStat s)
    {
        var history = s.SessionHistory;
        if (history.Count == 0) return new();

        var dataPoints = history
            .Where(h => h.Volume.HasValue && h.Volume.Value > 0)
            .Select(h => (h.Date, Value: h.Volume!.Value))
            .ToList();
        if (dataPoints.Count == 0) return new();

        var rawMax    = dataPoints.Max(p => p.Value);
        var yMax      = rawMax * 1.1;
        var minTicks  = dataPoints.Min(p => p.Date.Ticks);
        var maxTicks  = dataPoints.Max(p => p.Date.Ticks);
        var tickRange = maxTicks - minTicks;

        return dataPoints.Select((p, i) =>
        {
            var x = tickRange > 0
                ? CL + (double)(p.Date.Ticks - minTicks) / tickRange * CW
                : (dataPoints.Count > 1 ? CL + (double)i / (dataPoints.Count - 1) * CW : CL + CW / 2);
            var y = CB - p.Value / yMax * CH;
            return new ChartPoint(x, y, p.Date.ToString("d MMM yyyy"), FormatVolume(p.Value));
        }).ToList();
    }

    private static string Fmt(double v) =>
        v.ToString("0.##", CultureInfo.InvariantCulture);

    // ── Chart computation ─────────────────────────────────────────────

    private const double CL = 50d, CR = 550d, CT = 10d, CB = 125d;
    private const double CW = CR - CL, CH = CB - CT;

    private sealed record SessionPoint(DateTime Date, double? Weight, int? Duration, double? Distance, double? Pace, double? Volume);
    private sealed record ChartPoint(double X, double Y, string DateLabel, string ValueLabel);

    private sealed record ChartData(
        List<ChartPoint> Points,
        string           LinePath,
        string           AreaPath,
        string           YMaxLabel,
        string           YMinLabel,
        string           FirstDateLabel,
        string           LastDateLabel)
    {
        public static readonly ChartData Empty = new(new(), "", "", "", "", "", "");
    }

    private ChartData BuildChartData(ExerciseStat s)
    {
        var pts = BuildChartPoints(s);
        if (pts.Count == 0) return ChartData.Empty;

        var isWeight = s.Type == ExerciseType.RepsWeight;
        var isCardio = s.Type == ExerciseType.Cardio;
        var vals = s.SessionHistory
            .Select(h => isWeight ? (h.Weight ?? 0) : isCardio ? (h.Distance ?? 0) : (double)(h.Duration ?? 0))
            .Where(v => v > 0).ToList();
        if (vals.Count == 0) return ChartData.Empty;

        var rawMax    = vals.Max();
        var yMaxLabel = isWeight ? FormatWeight(rawMax) : isCardio ? FormatDistance(rawMax) : FormatDuration((int)rawMax);
        var firstDate = s.SessionHistory.First().Date.ToString("d MMM");
        var lastDate  = s.SessionHistory.Last().Date.ToString("d MMM yyyy");

        return new ChartData(pts, BuildLinePath(pts), BuildAreaPath(pts),
            yMaxLabel, "0", firstDate, lastDate);
    }

    private List<ChartPoint> BuildChartPoints(ExerciseStat s)
    {
        var history = s.SessionHistory;
        if (history.Count == 0) return new();

        var isWeight  = s.Type == ExerciseType.RepsWeight;
        var isCardio  = s.Type == ExerciseType.Cardio;
        var dataPoints = history
            .Select(h => (h.Date, Value: isWeight ? (h.Weight ?? 0) : isCardio ? (h.Distance ?? 0) : (double)(h.Duration ?? 0)))
            .Where(p => p.Value > 0)
            .ToList();
        if (dataPoints.Count == 0) return new();

        var rawMax    = dataPoints.Max(p => p.Value);
        var yMax      = rawMax * 1.1;
        var minTicks  = dataPoints.Min(p => p.Date.Ticks);
        var maxTicks  = dataPoints.Max(p => p.Date.Ticks);
        var tickRange = maxTicks - minTicks;

        return dataPoints.Select((p, i) =>
        {
            var x = tickRange > 0
                ? CL + (double)(p.Date.Ticks - minTicks) / tickRange * CW
                : (dataPoints.Count > 1 ? CL + (double)i / (dataPoints.Count - 1) * CW : CL + CW / 2);
            var y      = CB - p.Value / yMax * CH;
            var vLabel = isWeight ? FormatWeight(p.Value) : isCardio ? FormatDistance(p.Value) : FormatDuration((int)p.Value);
            return new ChartPoint(x, y, p.Date.ToString("d MMM yyyy"), vLabel);
        }).ToList();
    }

    private static string BuildLinePath(IReadOnlyList<ChartPoint> pts)
    {
        if (pts.Count == 0) return "";
        var sb = new System.Text.StringBuilder();
        sb.Append($"M {Fmt(pts[0].X)} {Fmt(pts[0].Y)}");
        for (int i = 1; i < pts.Count; i++)
            sb.Append($" L {Fmt(pts[i].X)} {Fmt(pts[i].Y)}");
        return sb.ToString();
    }

    private static string BuildAreaPath(IReadOnlyList<ChartPoint> pts)
    {
        if (pts.Count == 0) return "";
        var sb = new System.Text.StringBuilder();
        sb.Append($"M {Fmt(pts[0].X)} {Fmt(CB)}");
        sb.Append($" L {Fmt(pts[0].X)} {Fmt(pts[0].Y)}");
        for (int i = 1; i < pts.Count; i++)
            sb.Append($" L {Fmt(pts[i].X)} {Fmt(pts[i].Y)}");
        sb.Append($" L {Fmt(pts[^1].X)} {Fmt(CB)} Z");
        return sb.ToString();
    }

    // ── Data loading ─────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await WorkoutService.InitializeAsync();
        _workouts  = await WorkoutService.GetLoggedWorkoutsAsync();
        _templates = await WorkoutService.GetTemplatesAsync();
        var unitRaw = await JS.InvokeAsync<string?>("localStorage.getItem", "gym_tracker_weight_unit");
        _isMetric = unitRaw != "lbs";
        var distRaw = await JS.InvokeAsync<string?>("localStorage.getItem", "gym_tracker_distance_unit");
        _isKm = distRaw != "mi";
        var rangeRaw = await JS.InvokeAsync<string?>("localStorage.getItem", "gym_tracker_progress_range");
        if (int.TryParse(rangeRaw, out var rd) && (rd == 0 || rd == 30 || rd == 90 || rd == 365))
            _rangeDays = rd;
        BuildStats();
    }

    private void BuildStats()
    {
        if (_workouts is null) return;

        // Apply the active date-range filter so all per-exercise stats reflect it.
        var sourceWorkouts = WorkoutsInRange;

        // Group every LoggedExercise across all workouts by exercise name
        var byName = new Dictionary<string, List<(DateTime Date, LoggedExercise Ex)>>(
            StringComparer.OrdinalIgnoreCase);

        foreach (var workout in sourceWorkouts)
        {
            foreach (var ex in workout.Exercises)
            {
                if (string.IsNullOrWhiteSpace(ex.Name)) continue;
                if (!byName.TryGetValue(ex.Name, out var list))
                    byName[ex.Name] = list = new();
                list.Add((workout.Date, ex));
            }
        }

        _stats = byName.Select(kvp =>
        {
            var sessions = kvp.Value.OrderBy(x => x.Date).ToList();

            // Best weight per session (RepsWeight exercises)
            var weightSessions = sessions
                .Select(s => s.Ex.Sets
                    .Where(set => set.WeightKg.HasValue)
                    .Select(set => set.WeightKg!.Value)
                    .DefaultIfEmpty(0d).Max())
                .Select((best, i) => (Index: i, Best: best))
                .Where(x => x.Best > 0)
                .ToList();

            double? firstBestWeight    = weightSessions.Count > 0 ? weightSessions.First().Best       : null;
            double? latestBestWeight   = weightSessions.Count > 0 ? weightSessions.Last().Best        : null;
            double? allTimeBestWeight  = weightSessions.Count > 0 ? weightSessions.Max(x => x.Best)   : null;

            // Best duration per session (Timed exercises)
            var durationSessions = sessions
                .Select(s => s.Ex.Sets
                    .Where(set => set.DurationSeconds.HasValue)
                    .Select(set => set.DurationSeconds!.Value)
                    .DefaultIfEmpty(0).Max())
                .Select((best, i) => (Index: i, Best: best))
                .Where(x => x.Best > 0)
                .ToList();

            int? firstBestDuration    = durationSessions.Count > 0 ? durationSessions.First().Best      : null;
            int? latestBestDuration   = durationSessions.Count > 0 ? durationSessions.Last().Best       : null;
            int? allTimeBestDuration  = durationSessions.Count > 0 ? durationSessions.Max(x => x.Best)  : null;

            // Best distance per session (Cardio exercises)
            var distanceSessions = sessions
                .Select(s => s.Ex.Sets.Sum(set => set.DistanceKm ?? 0))
                .Select((dist, i) => (Index: i, Dist: dist))
                .Where(x => x.Dist > 0)
                .ToList();

            double? firstBestDistance   = distanceSessions.Count > 0 ? distanceSessions.First().Dist : null;
            double? latestBestDistance  = distanceSessions.Count > 0 ? distanceSessions.Last().Dist  : null;
            double? allTimeBestDistance = distanceSessions.Count > 0 ? distanceSessions.Max(x => x.Dist) : null;
            double  totalDistanceKm     = sessions.Sum(s => s.Ex.Sets.Sum(set => set.DistanceKm ?? 0));

            // Best (fastest = lowest) pace per session (Cardio)
            var paceSessions = sessions
                .Select(s =>
                {
                    var pace = s.Ex.Sets
                        .Where(set => set.DistanceKm > 0 && set.DurationSeconds > 0)
                        .Select(set => set.DurationSeconds!.Value / 60.0 / set.DistanceKm!.Value)
                        .DefaultIfEmpty(0d).Min();
                    return (s.Date, Pace: pace);
                })
                .Where(x => x.Pace > 0)
                .ToList();

            double? firstBestPace   = paceSessions.Count > 0 ? paceSessions.First().Pace              : null;
            double? latestBestPace  = paceSessions.Count > 0 ? paceSessions.Last().Pace               : null;
            double? allTimeBestPace = paceSessions.Count > 0 ? paceSessions.Min(x => x.Pace)          : null;

            // ── Real PR count ────────────────────────────────────────
            // A session is a PR if its best metric strictly beats every previous
            // session's best (lower for pace, higher for everything else).
            int prCount  = 0;
            double bestW = 0, bestDist = 0; int bestDur = 0; double bestPaceLow = double.MaxValue;
            bool anyW = false, anyDist = false, anyDur = false, anyPace = false;
            foreach (var s in sessions)
            {
                var w = s.Ex.Sets.Where(x => x.WeightKg.HasValue).Select(x => x.WeightKg!.Value).DefaultIfEmpty(0d).Max();
                var d = s.Ex.Sets.Where(x => x.DurationSeconds.HasValue).Select(x => x.DurationSeconds!.Value).DefaultIfEmpty(0).Max();
                var dist = s.Ex.Sets.Sum(x => x.DistanceKm ?? 0);
                var pace = s.Ex.Sets
                    .Where(x => x.DistanceKm > 0 && x.DurationSeconds > 0)
                    .Select(x => x.DurationSeconds!.Value / 60.0 / x.DistanceKm!.Value)
                    .DefaultIfEmpty(0d).Min();

                bool pr = false;
                if (w    > 0       && (!anyW    || w    > bestW))       { pr = true; bestW = w; anyW = true; }
                else if (w    > 0  && !anyW)                              { anyW = true; bestW = w; }
                if (d    > 0       && (!anyDur  || d    > bestDur))     { pr = true; bestDur = d; anyDur = true; }
                if (dist > 0       && (!anyDist || dist > bestDist))    { pr = true; bestDist = dist; anyDist = true; }
                if (pace > 0       && (!anyPace || pace < bestPaceLow)) { pr = true; bestPaceLow = pace; anyPace = true; }
                if (pr) prCount++;
            }

            return new ExerciseStat
            {
                Name                = kvp.Key,
                MuscleGroup         = GetMuscleGroup(kvp.Key),
                Type                = sessions.First().Ex.Type,
                SessionCount        = sessions.Count,
                FirstDate           = sessions.First().Date,
                LastDate            = sessions.Last().Date,
                FirstBestWeight     = firstBestWeight,
                LatestBestWeight    = latestBestWeight,
                AllTimeBestWeight   = allTimeBestWeight,
                FirstBestDuration   = firstBestDuration,
                LatestBestDuration  = latestBestDuration,
                AllTimeBestDuration = allTimeBestDuration,
                FirstBestDistance   = firstBestDistance,
                LatestBestDistance  = latestBestDistance,
                AllTimeBestDistance = allTimeBestDistance,
                TotalDistanceKm     = totalDistanceKm,
                FirstBestPace       = firstBestPace,
                LatestBestPace      = latestBestPace,
                AllTimeBestPace     = allTimeBestPace,
                TotalSets           = sessions.Sum(s => s.Ex.Sets.Count),
                TotalReps           = sessions.Sum(s => s.Ex.Sets.Sum(set => set.Reps ?? 0)),
                PoCount             = sessions.Count(s => s.Ex.ProgressiveOverload),
                PrCount             = prCount,
                BestEstimated1RM    = sessions
                    .SelectMany(s => s.Ex.Sets)
                    .Where(set => set.WeightKg > 0 && set.Reps > 0)
                    .Select(set => set.WeightKg!.Value * (1.0 + set.Reps!.Value / 30.0))
                    .DefaultIfEmpty(0d).Max() is > 0d and var rm ? rm : (double?)null,
                TotalVolumeKg       = sessions
                    .SelectMany(s => s.Ex.Sets)
                    .Where(set => set.WeightKg > 0 && set.Reps > 0)
                    .Sum(set => set.WeightKg!.Value * set.Reps!.Value),
                SessionHistory      = sessions.Select(s =>
                {
                    var w    = s.Ex.Sets.Where(set => set.WeightKg.HasValue)
                                         .Select(set => set.WeightKg!.Value)
                                         .DefaultIfEmpty(0d).Max();
                    var d    = s.Ex.Sets.Where(set => set.DurationSeconds.HasValue)
                                         .Select(set => set.DurationSeconds!.Value)
                                         .DefaultIfEmpty(0).Max();
                    var dist = s.Ex.Sets.Sum(set => set.DistanceKm ?? 0);
                    var pace = s.Ex.Sets
                        .Where(set => set.DistanceKm > 0 && set.DurationSeconds > 0)
                        .Select(set => set.DurationSeconds!.Value / 60.0 / set.DistanceKm!.Value)
                        .DefaultIfEmpty(0d).Min();
                    var vol  = s.Ex.Sets
                        .Where(set => set.WeightKg > 0 && set.Reps > 0)
                        .Sum(set => set.WeightKg!.Value * set.Reps!.Value);
                    return new SessionPoint(s.Date, w > 0 ? w : null, d > 0 ? d : null, dist > 0 ? dist : null, pace > 0 ? pace : null, vol > 0 ? vol : null);
                }).ToArray()
            };
        }).ToList();
    }

    // ── Per-exercise computed stats ───────────────────────────────────

    private sealed class ExerciseStat
    {
        public string       Name                { get; init; } = "";
        public string?      MuscleGroup         { get; init; }
        public ExerciseType Type                { get; init; }
        public int          SessionCount        { get; init; }
        public DateTime     FirstDate           { get; init; }
        public DateTime     LastDate            { get; init; }
        public double?      FirstBestWeight     { get; init; }
        public double?      LatestBestWeight    { get; init; }
        public double?      AllTimeBestWeight   { get; init; }
        public int?         FirstBestDuration   { get; init; }
        public int?         LatestBestDuration  { get; init; }
        public int?         AllTimeBestDuration { get; init; }
        public double?      FirstBestDistance   { get; init; }
        public double?      LatestBestDistance  { get; init; }
        public double?      AllTimeBestDistance { get; init; }
        public double       TotalDistanceKm     { get; init; }
        public double?      FirstBestPace       { get; init; }   // min/km, lower = faster
        public double?      LatestBestPace      { get; init; }
        public double?      AllTimeBestPace     { get; init; }   // best (lowest) ever
        public int          TotalSets           { get; init; }
        public int          TotalReps           { get; init; }
        public int          PoCount             { get; init; }
        public int          PrCount             { get; init; }
        public double?      BestEstimated1RM    { get; init; }
        public double       TotalVolumeKg       { get; init; }
        public IReadOnlyList<SessionPoint> SessionHistory { get; init; } = Array.Empty<SessionPoint>();

        // Derived – Weight
        public double? WeightDelta =>
            LatestBestWeight.HasValue && FirstBestWeight.HasValue
                ? LatestBestWeight.Value - FirstBestWeight.Value : null;

        public double? WeightDeltaPct =>
            WeightDelta.HasValue && FirstBestWeight is > 0
                ? WeightDelta.Value / FirstBestWeight.Value * 100 : null;

        public double BarWidthPct =>
            AllTimeBestWeight is > 0 && LatestBestWeight.HasValue
                ? Math.Min(100d, LatestBestWeight.Value / AllTimeBestWeight.Value * 100d) : 0d;

        // Derived – Duration
        public int? DurationDelta =>
            LatestBestDuration.HasValue && FirstBestDuration.HasValue
                ? LatestBestDuration.Value - FirstBestDuration.Value : null;

        public double? DurationDeltaPct =>
            DurationDelta.HasValue && FirstBestDuration is > 0
                ? (double)DurationDelta.Value / FirstBestDuration.Value * 100 : null;

        public double DurationBarWidthPct =>
            AllTimeBestDuration is > 0 && LatestBestDuration.HasValue
                ? Math.Min(100d, (double)LatestBestDuration.Value / AllTimeBestDuration.Value * 100d) : 0d;

        // Derived – Distance (Cardio)
        public double? DistanceDelta =>
            LatestBestDistance.HasValue && FirstBestDistance.HasValue
                ? LatestBestDistance.Value - FirstBestDistance.Value : null;

        public double? DistanceDeltaPct =>
            DistanceDelta.HasValue && FirstBestDistance is > 0
                ? DistanceDelta.Value / FirstBestDistance.Value * 100 : null;

        public double DistanceBarWidthPct =>
            AllTimeBestDistance is > 0 && LatestBestDistance.HasValue
                ? Math.Min(100d, LatestBestDistance.Value / AllTimeBestDistance.Value * 100d) : 0d;

        // Derived – Pace (Cardio, lower = faster = better)
        public double? PaceDelta =>
            LatestBestPace.HasValue && FirstBestPace.HasValue
                ? LatestBestPace.Value - FirstBestPace.Value : null;   // negative = improvement

        public double? PaceDeltaPct =>
            PaceDelta.HasValue && FirstBestPace is > 0
                ? PaceDelta.Value / FirstBestPace.Value * 100 : null;

        // Bar: how close latest pace is to all-time best (100% when equal)
        public double PaceBarWidthPct =>
            AllTimeBestPace is > 0 && LatestBestPace is > 0
                ? Math.Min(100d, AllTimeBestPace.Value / LatestBestPace.Value * 100d) : 0d;

        /// <summary>Used for "most improved" sort order.</summary>
        public double ImprovementPct => WeightDeltaPct ?? DurationDeltaPct ?? DistanceDeltaPct ?? -(PaceDeltaPct ?? 0);

        public string AvgGapText =>
            SessionCount > 1
                ? $"every {(int)Math.Round((LastDate - FirstDate).TotalDays / (SessionCount - 1))} days"
                : "1 session";

        public string FrequencyText
        {
            get
            {
                if (SessionCount < 2) return "";
                var weeks = (LastDate - FirstDate).TotalDays / 7.0;
                if (weeks < 1) return "";
                return $"{(SessionCount / weeks).ToString("0.#", CultureInfo.InvariantCulture)}×/wk";
            }
        }
    }

    // ── Template grouping ─────────────────────────────────────────────

    private sealed record StatGroup(string Name, List<ExerciseStat> Stats);

    private IEnumerable<StatGroup> AllGroups => _sort == "template"
        ? TemplateGroups
        : new[] { new StatGroup("", FilteredStats.ToList()) };

    private IEnumerable<StatGroup> TemplateGroups
    {
        get
        {
            var groups = new Dictionary<string, List<ExerciseStat>>(StringComparer.OrdinalIgnoreCase);
            var source = _muscleFilter is null
                ? _stats
                : _stats.Where(s => string.Equals(s.MuscleGroup, _muscleFilter, StringComparison.OrdinalIgnoreCase)).ToList();
            foreach (var s in source)
            {
                var tName = PrimaryTemplateName(s.Name);
                if (!groups.TryGetValue(tName, out var list))
                    groups[tName] = list = new();
                list.Add(s);
            }
            return groups
                .OrderBy(kvp => kvp.Key == "No template" ? 1 : 0)
                .ThenBy(kvp => kvp.Key, StringComparer.OrdinalIgnoreCase)
                .Select(kvp => new StatGroup(kvp.Key, kvp.Value.OrderBy(s => s.Name).ToList()));
        }
    }

    private string PrimaryTemplateName(string exerciseName)
    {
        if (_templates is null || _templates.Count == 0) return "No template";
        var template = _templates.FirstOrDefault(t =>
            t.Exercises.Any(e => string.Equals(e.Name, exerciseName, StringComparison.OrdinalIgnoreCase)));
        return template?.Name ?? "No template";
    }
}

