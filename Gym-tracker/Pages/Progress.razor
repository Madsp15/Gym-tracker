    private string FormatWeight(double kg)
    {
        var v = _isMetric ? kg : Math.Round(kg * 2.20462, 1);
        return v.ToString("0.##", CultureInfo.InvariantCulture) + " " + WeightUnit;
    }

    private static string FormatDistance(double km, bool isKm, string unit)
    {
        var v = isKm ? km : Math.Round(km * 0.621371, 3);
        return v.ToString("0.##", CultureInfo.InvariantCulture) + " " + unit;
    }

    private string FormatDistance(double km) => FormatDistance(km, _isKm, DistanceUnit);

    private string FormatVolume(double kg)
    {
        var v = _isMetric ? kg : kg * 2.20462;
        if (v >= 1_000_000) return $"{v / 1_000_000:0.#}M {WeightUnit}";
        if (v >= 1_000)     return $"{v / 1_000:0.#}k {WeightUnit}";
        return $"{(int)v} {WeightUnit}";
    }

    private static string FormatDuration(int seconds)
    {
        if (seconds <= 0) return "0s";
        var mins = seconds / 60;
        var secs = seconds % 60;
        if (mins > 0 && secs > 0) return $"{mins}m {secs}s";
        if (mins > 0)             return $"{mins}m";
        return $"{secs}s";
    }

