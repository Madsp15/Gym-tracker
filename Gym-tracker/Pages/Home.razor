@page "/"

<PageTitle>Gym Tracker</PageTitle>

<div class="home-hero">
    <div class="home-hero__inner">
        <span class="home-hero__icon">🏋️</span>
        <h1 class="home-hero__title">Gym Tracker</h1>
        <p class="home-hero__subtitle">Log your workouts, track your progress, crush your goals.</p>
    </div>
</div>

<div class="home-cards">
    <a href="workouts" class="home-card">
        <div class="home-card__icon">📋</div>
        <div class="home-card__label">Workouts</div>
        <div class="home-card__hint">Log &amp; manage</div>
    </a>
    <div class="home-card home-card--placeholder">
        <div class="home-card__icon">📈</div>
        <div class="home-card__label">Progress</div>
        <div class="home-card__hint">Coming soon</div>
    </div>
    <div class="home-card home-card--placeholder">
        <div class="home-card__icon">🎯</div>
        <div class="home-card__label">Goals</div>
        <div class="home-card__hint">Coming soon</div>
    </div>
</div>

